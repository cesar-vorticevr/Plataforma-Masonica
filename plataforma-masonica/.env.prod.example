# Plantilla de PRODUCCIÓN. Copia a .env.prod y rellena con los valores reales del
# proyecto Supabase de producción. .env.prod está en .gitignore: NUNCA lo subas al repo.
#
# Para el despliegue en Vercel, estas variables se configuran en el DASHBOARD del proyecto
# (Settings > Environment Variables), no desde un archivo del repo. Este .env.prod sirve para
# correr scripts/builds de producción localmente (p. ej. `node --env-file=.env.prod scripts/crear-master.mjs`).

NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-o-publishable-key-de-produccion
# Service role: SOLO servidor/scripts. NUNCA con prefijo NEXT_PUBLIC_. NUNCA en el cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-de-produccion

# --- Administrador maestro (para `node --env-file=.env.prod scripts/crear-master.mjs`) ---
MASTER_EMAIL=master@restauracion.org.mx
# MASTER_PASSWORD=opcional (si se omite, el script genera una segura y la muestra una vez)
# MASTER_NOMBRE=Administrador Master
