# Copia este archivo a .env.local y rellena los valores.
# .env.local está en .gitignore (NO lo subas; nunca pongas llaves reales aquí).
# La app SIEMPRE usa Supabase (no hay modo mock).

# --- Supabase LOCAL (desarrollo) ---
# Levanta el stack con `npx supabase start` y obtén estos valores con `npx supabase status`.
# La anon key local es un JWT de desarrollo (NO es secreta ni sirve en producción).
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=pega-aqui-el-anon-key-de-supabase-status
# Service role: SOLO servidor (registro, scripts). NUNCA con prefijo NEXT_PUBLIC_. De `supabase status`.
SUPABASE_SERVICE_ROLE_KEY=pega-aqui-el-service-role-key-de-supabase-status

# --- Administrador maestro (para `npm run crear:master`) ---
MASTER_EMAIL=master@restauracion.org.mx
# MASTER_PASSWORD: si se omite, `crear:master` genera una segura y la escribe AQUÍ automáticamente.
# MASTER_NOMBRE=Administrador Master
